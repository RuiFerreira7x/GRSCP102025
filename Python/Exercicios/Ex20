import random

matriz = [[random.randint(1, 20) for x in range(3)] for x in range(3)]

# soma pares e ímpares
soma_pares = 0
soma_impares = 0

for i in range(3):
    for j in range(3):
        if matriz[i][j] % 2 == 0:
            soma_pares += matriz[i][j]
        else:
            soma_impares += matriz[i][j]

# mostra resultados
print("Matriz:")
for linha in matriz:
    print(linha)
print(f"Soma dos pares: {soma_pares}")
print(f"Soma dos ímpares: {soma_impares}")
