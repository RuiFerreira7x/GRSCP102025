import random

matriz = [[random.randint(1, 20) for x in range(3)] for x in range(3)]

print("Matriz 3x3:")
for linha in matriz:
    print(linha)

somas_linhas = [sum(linha) for linha in matriz]
maior_soma = max(somas_linhas)

print("\nLinha com maior soma (índice", somas_linhas, "):")
print("Maior soma =", maior_soma)